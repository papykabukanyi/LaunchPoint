# =============================================
# LAUNCHPOINT DM — ENVIRONMENT CONFIG TEMPLATE
# =============================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to git — it contains secrets.

# ---- Server ----
PORT=3300
NODE_ENV=production

# ---- PostgreSQL Database ----
# Railway provides this automatically when you add a Postgres plugin
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# ---- Email (Gmail with App Password) ----
# 1. Enable 2FA on your Google account
# 2. Visit https://myaccount.google.com/apppasswords
# 3. Generate an App Password for Mail
EMAIL_USER=hello@launchpoint-dm.com
EMAIL_PASS=your-gmail-app-password
NOTIFICATION_EMAIL=hello@launchpoint-dm.com

# ---- JWT Secret ----
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-string

# ---- CORS ----
ALLOWED_ORIGINS=https://launchpoint-dm.com,https://www.launchpoint-dm.com

# ---- Admin Portal URL ----
ADMIN_URL=https://launchpoint-dm.com/admin

# ---- Superadmin Account ----
# Seeds the initial superadmin on first startup
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_EMAIL=hello@launchpoint-dm.com
SUPERADMIN_PASSWORD=ChangeThisToSomethingStrong!

# ---- SMS / Text Notifications (Vonage) ----
# Sign up free at https://dashboard.nexmo.com (no credit card for sandbox)
# Vonage is a Twilio alternative with competitive pricing
VONAGE_API_KEY=your-vonage-api-key
VONAGE_API_SECRET=your-vonage-api-secret
VONAGE_FROM=LaunchPoint
VONAGE_TO_NUMBER=+15559876543

# ---- Analytics (optional) ----
GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
GOOGLE_TAG_MANAGER_ID=

# ---- Social (optional) ----
DEFAULT_SOCIAL_FACEBOOK=https://facebook.com/launchpointdm
DEFAULT_SOCIAL_TWITTER=https://twitter.com/launchpointdm
DEFAULT_SOCIAL_INSTAGRAM=https://instagram.com/launchpointdm
DEFAULT_SOCIAL_LINKEDIN=https://linkedin.com/company/launchpointdm

TWILIO_AUTH_TOKEN=
TWILIO_PHONE=+15551234567

# Analytics & SEO
GOOGLE_ANALYTICS_ID=
FACEBOOK_PIXEL_ID=
GOOGLE_TAG_MANAGER_ID=

# Social Media & Marketing
DEFAULT_SOCIAL_FACEBOOK=
DEFAULT_SOCIAL_TWITTER=
DEFAULT_SOCIAL_INSTAGRAM=
MARKETING_FIRM_NAME=Blue Ocean Strategies
MARKETING_FIRM_WEBSITE=https://blueoceanstrategies.com
MARKETING_FIRM_PHONE=(555) 123-4567

# File Upload Configuration
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=jpeg,jpg,png,pdf,doc,docx

# Rate Limiting
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100
FORM_LIMIT_MAX=5