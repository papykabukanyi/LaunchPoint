# Political Marketing Platform Environment Configuration

# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration (SQLite is used by default, no additional config needed)
# For production, consider PostgreSQL or MySQL

# Email Configuration (for contact form notifications)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
NOTIFICATION_EMAIL=admin@yourmarketingfirm.com

# JWT Secret (CHANGE THIS IN PRODUCTION!)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-make-it-long-and-random

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# Admin Configuration
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@yourmarketingfirm.com
ADMIN_PASSWORD=ChangeThisPassword123!

# Analytics & SEO
GOOGLE_ANALYTICS_ID=
FACEBOOK_PIXEL_ID=
GOOGLE_TAG_MANAGER_ID=

# Social Media & Marketing
DEFAULT_SOCIAL_FACEBOOK=
DEFAULT_SOCIAL_TWITTER=
DEFAULT_SOCIAL_INSTAGRAM=
MARKETING_FIRM_NAME=Your Marketing Firm
MARKETING_FIRM_WEBSITE=https://yourmarketingfirm.com
MARKETING_FIRM_PHONE=(555) 123-4567

# File Upload Configuration
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=jpeg,jpg,png,pdf,doc,docx

# Rate Limiting
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100
FORM_LIMIT_MAX=5